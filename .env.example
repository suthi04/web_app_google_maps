# ===== InsightReview — config =====
# วิธีใช้: คัดลอกไฟล์นี้เป็นชื่อ ".env" (ไม่มี .example) แล้วใส่ค่าของคุณ
# ระบบจะอ่าน .env อัตโนมัติทุกครั้งที่รัน — ไม่ต้อง set ใน terminal อีก
#
#   Windows : copy .env.example .env
#   Mac/Linux: cp .env.example .env
# แล้วเปิดไฟล์ .env แก้ค่าด้านล่าง

# ---------- ดึงรีวิวจริงจาก Google Maps (ออกจากโหมด demo) ----------
# ใส่ Apify token ของคุณ (สมัครฟรีที่ apify.com -> Settings -> API tokens)
APIFY_TOKEN=

# จำนวนรีวิวที่ดึงต่อร้าน (100 กำลังดี เร็วและพอวิเคราะห์)
MAX_REVIEWS=100

# ---------- ใช้ WangchanBERTa วิเคราะห์อารมณ์จริง ----------
# ต้องติดตั้งก่อน: pip install -r requirements-model.txt
# แล้วเปลี่ยนเป็น 1
USE_MODEL=0

# ---------- อื่น ๆ (ไม่ต้องแก้) ----------
# PORT=5000
# APIFY_TIMEOUT=300
